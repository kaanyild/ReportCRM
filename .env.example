# ============================================
# Müşteri Rapor Sistemi — Ortam Değişkenleri
# ============================================

# Google Analytics 4
# Service Account oluşturmak için: https://console.cloud.google.com/iam-admin/serviceaccounts
# GA4 Property'ye Analytics Viewer rolü vermeyi unutmayın
GA4_PROPERTY_ID=properties/XXXXXXXXX
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Meta Ads (Facebook/Instagram)
# Token almak için: https://business.facebook.com/settings
# Uzun ömürlü token için System User kullanın
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# Rapor Ayarları
REPORT_DATE_RANGE=last_30d        # last_7d | last_30d | last_90d
CLIENT_NAME=Müşteri Adı
OUTPUT_DIR=./raporlar
